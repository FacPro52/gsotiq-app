                title: 'Eliminate caffeine after 1:00 PM',
                links: [{ title: 'Recommended Resource', url: 'https://www.example.com/' }],
                tasks: [
                  { title: 'Switch afternoon coffee to decaf or herbal tea' },
                  { title: 'Replace the 3 PM coffee ritual with a 10-minute walk instead' },
                  { title: 'Note in sleep log when caffeine was last consumed and compare sleep quality' },
                ],
              },
              {
                title: 'Manage light exposure to optimize melatonin production',
                description: 'Light is the strongest regulator of your circadian rhythm. Control it strategically.',
                links: [{ title: 'Circadian Rhythm', url: 'https://sleep.hms.harvard.edu/' }, { title: 'Light and Sleep', url: 'https://www.mayoclinic.org/healthy-lifestyle/adult-health/in-depth/sleep/art-20048379' }],
                tasks: [
                  { title: 'Get 10–15 minutes of bright morning sunlight within 1 hour of waking to anchor your circadian rhythm' },
                  { title: 'Use blue light glasses or reduce screen brightness after 7 PM to minimize melatonin suppression' },
                  { title: 'Dim the lights in your home 30 minutes before your target bedtime' },
                  { title: 'Consider a light therapy lamp (10,000 lux) for winter months if you live in low-light climates' },
                ],
              },
            ],
          },
        ],
      },
      {
        title: 'Address lifestyle factors that undermine sleep quality',
        description: 'Diet, exercise, stress, and substances all directly affect your ability to fall and stay asleep.',
        objectives: [
          {
            title: 'Eliminate the top three sleep disruptors from your routine',
            description: 'Alcohol, late-night eating, and excessive caffeine are the most common culprits that fragment sleep architecture.',
            measures: 'Sleep disruptors eliminated from routine for 4 consecutive weeks; sleep score improves by 10+ points',
            tactics: [
              {
                title: 'Audit and eliminate alcohol and late-night eating as sleep disruptors',
                description: 'Alcohol suppresses REM sleep and causes early waking. Late meals elevate core body temperature, delaying sleep onset.',
                tasks: [
                  { title: 'Limit alcohol to no more than 1 drink, consumed at least 3 hours before bed' },
                  { title: 'Stop eating solid food at least 2 hours before your target bedtime' },
                  { title: 'If hungry late, choose a small, sleep-supportive snack: a few almonds, cottage cheese, or tart cherry juice' },
                  { title: 'Track how alcohol-free nights compare to drinking nights in your sleep log' },
                ],
              },
              {
                title: 'Time exercise and meals to support your sleep schedule',
                description: 'When you exercise and eat matters almost as much as what you do.',
                tasks: [
                  { title: 'Avoid intense exercise within 2–3 hours of bedtime — schedule hard workouts before 6 PM' },
                  { title: 'Eat your largest meal at lunch or early dinner — not within 2 hours of sleep' },
                  { title: 'Do light stretching or yoga in the evening instead of vigorous cardio' },
                ],
              },
            ],
          },
          {
            title: 'Use stress management techniques specifically to improve sleep onset',
            description: 'Anxiety and mental chatter are the leading cause of difficulty falling asleep.',
            measures: 'Average sleep onset time under 20 minutes for 3 consecutive weeks; tracked via wearable or sleep diary',
            tactics: [
              {
                title: 'Practice a cognitive offload routine before bed',
                description: 'Writing down tomorrow\'s tasks and worries clears the mind so the brain can disengage.',
                tasks: [
                  { title: 'Spend 5 minutes each evening writing a "brain dump" — every task, worry, and thought in your head' },
                  { title: 'Write tomorrow\'s top 3 priorities the night before so your brain doesn\'t rehearse them during the night' },
                  { title: 'Use a "worry time" technique: designate 15 minutes earlier in the evening to think through concerns — not in bed' },
                ],
              },
              {
                title: 'Use progressive relaxation or yoga nidra to physically prepare the body for sleep',
                description: 'Physical relaxation techniques lower heart rate and muscle tension — the body\'s prerequisites for deep sleep.',
                tasks: [
                  { title: 'Try a 10-minute yoga nidra session (guided body scan) in bed using Insight Timer or YouTube' },
                  { title: 'Practice progressive muscle relaxation: tense and release each muscle group from feet to face' },
                  { title: 'Use 4-7-8 breathing (inhale 4, hold 7, exhale 8) when lying down to activate the parasympathetic nervous system' },
                ],
              },
            ],
          },
        ],
      },
    ],
  },

  {
    id: 'hw_stress',
    categoryId: 'health_wellness',
    title: 'Manage Stress & Anxiety',
    description: 'Build evidence-based daily practices to reduce chronic stress, lower anxiety, and strengthen emotional resilience.',
    category: 'health',
    strategies: [
      {
        title: 'Practice daily stress-reduction rituals',
        description: 'Make stress management a proactive daily habit, not just a crisis response.',
        objectives: [
          {
            title: 'Complete 10 minutes of mindfulness or breathwork daily for 8 weeks',
            description: 'Consistent practice reduces cortisol levels and reactive anxiety.',
            measures: 'Sessions logged daily; Perceived Stress Scale (PSS) score down ≥30% from baseline at 8 weeks',
            tactics: [
              {
                title: 'Build a morning mindfulness habit',
                links: [{ title: 'Insight Timer App', url: 'https://insighttimer.com/' }, { title: 'Meditation Basics', url: 'https://www.psychologytoday.com/us/basics/meditation' }, { title: 'Mindfulness Meditation', url: 'https://www.mindful.org/meditation/' }],
                tasks: [
                  { title: 'Download a guided meditation app (Headspace, Calm, or Insight Timer)' },
                  { title: 'Start with 5 minutes and build to 15–20 min over 4 weeks' },
                  { title: 'Meditate before checking phone — anchor it right after waking' },
                  { title: 'Log each session and rate mood before and after (1–10) to reinforce' },
                ],
              },
              {
                title: 'Practice box breathing or 4-7-8 breathing during moments of acute stress',
                description: 'Quick breathing techniques can immediately activate your parasympathetic nervous system.',
                links: [{ title: 'Breathing Techniques', url: 'https://www.mayoclinic.org/healthy-lifestyle/stress-management/in-depth/relaxation-technique/art-20045368' }],
                tasks: [
                  { title: 'Learn two breathing techniques: box breathing (4-4-4-4) and 4-7-8 breathing' },
                  { title: 'Practice these techniques daily for 2 minutes — not just during stress — so they\'re automatic' },
                  { title: 'When you feel stress rising, use box breathing for 2 minutes before responding' },
                  { title: 'Use 4-7-8 breathing before bed to calm your nervous system and improve sleep' },
                ],
              },
            ],
          },
          {
            title: 'Use exercise as a primary stress-relief outlet at least 4x per week',
            description: 'Physical activity is one of the most effective evidence-based antidotes to anxiety.',
            measures: 'Exercise ≥4x/week logged; self-reported stress level ≤4/10 after sessions for 6 weeks',
            tactics: [
              {
                title: 'Schedule and show up for stress-relief workouts',
                links: [{ title: 'Recommended Resource', url: 'https://www.example.com/' }],
                tasks: [
                  { title: 'Choose a stress-relieving modality: yoga, walking, running, cycling, or swimming' },
                  { title: 'Block 30-minute workout windows in the calendar 4x/week' },
                  { title: 'Use exercise as a decompression buffer between work and home time' },
                  { title: 'Note energy and stress levels before and after each session' },
                ],
              },
              {
                title: 'Try progressive muscle relaxation to release stored physical tension',
                description: 'Stress lives in the body. Releasing physical tension breaks the stress cycle.',
                links: [{ title: 'Muscle Relaxation', url: 'https://www.mayoclinic.org/healthy-lifestyle/stress-management/in-depth/relaxation-technique/art-20045368' }],
                tasks: [
                  { title: 'Learn progressive muscle relaxation (PMR): tense and release each muscle group for 5 seconds' },
                  { title: 'Practice PMR for 10 minutes before bed 3x per week to reduce nighttime tension' },
                  { title: 'Do a quick 2-minute neck and shoulder tension release during stressful moments at work' },
                  { title: 'Combine PMR with deep breathing — inhale while tensing, exhale while releasing' },
                ],
              },
            ],
          },
        ],
      },
      {
        title: 'Identify and address root causes of stress',
        description: 'Tackle structural sources rather than just managing symptoms.',
        objectives: [
          {
            title: 'Complete a stress audit and implement 3 lasting changes within 60 days',
            description: 'Identifying triggers allows for targeted, durable solutions.',
            measures: '3 structural changes fully implemented; weekly stress journal shows declining trigger frequency',
            tactics: [
              {
                title: 'Map, rank, and systematically reduce top stress triggers',
                links: [{ title: 'Recommended Resource', url: 'https://www.example.com/' }],
                tasks: [
                  { title: 'List every recurring stressor — work overload, finances, relationships, health, time' },
                  { title: 'Rate each trigger by frequency × intensity; circle the top 3' },
                  { title: 'For each top stressor, identify 2 structural changes (delegation, boundary, system)' },
                  { title: 'Implement one change per week and review impact at month-end' },
                  { title: 'Consider working with a therapist or coach for deep-seated anxiety' },
                ],
              },
              {
                title: 'Create a written stress response plan for your top 3 triggers',
                description: 'When stressed, the brain\'s prefrontal cortex goes offline. Having a written plan prevents reactive behavior.',
                links: [{ title: 'Stress Management', url: 'https://www.mayoclinic.org/healthy-lifestyle/stress-management/' }],
                tasks: [
                  { title: 'For each of your top 3 stressors, write a specific 3-step action plan (e.g., pause → breathe → choose response)' },
                  { title: 'Keep your written plan visible: on your bathroom mirror, phone lock screen, or desk' },
                  { title: 'Rehearse your plan mentally during calm moments so it becomes automatic' },
                  { title: 'Practice your plan in low-stakes situations before a major trigger occurs' },
                ],
              },
            ],
          },
          {
            title: 'Build healthy boundaries and learn to say no to additional demands',
            description: 'Most chronic stress comes from over-commitment. Boundaries are the foundation of sustainable wellbeing.',
            measures: 'At least 3 new boundaries established and maintained; reduced hours/workload or number of commitments',
            tactics: [
              {
                title: 'Identify areas where you\'re over-committed and communicate new boundaries',
                description: 'Boundaries are not selfish — they\'re necessary for your health.',
                links: [{ title: 'Setting Boundaries', url: 'https://www.psychologytoday.com/us/basics/relationships' }],
                tasks: [
                  { title: 'List all your current commitments and time obligations — work, family, social, volunteer' },
                  { title: 'Circle the commitments that don\'t align with your values or are draining your energy' },
                  { title: 'Practice saying "no" or "not right now" to new requests for at least 3 commitments' },
                  { title: 'Communicate your boundaries clearly and kindly: "I\'ve realized I need to protect my time for health"' },
                ],
              },
              {
                title: 'Design a lower-stress weekly schedule with built-in recovery time',
                description: 'A sustainable schedule prevents stress accumulation before it starts.',
                tasks: [
                  { title: 'Block at least one 30-minute unscheduled recovery period each workday — protect it like a meeting' },
                  { title: 'Plan one full "off" day each week with no work tasks or stressful commitments' },
                  { title: 'Review your upcoming week every Sunday and identify any overloaded days — redistribute or cancel' },
                ],
              },
            ],
          },
        ],
      },
    ],
  },
  {
    id: 'hw_yoga_meditation',
    categoryId: 'health_wellness',
    title: 'Build a Yoga & Meditation Practice',
    description: 'Develop a consistent yoga and meditation routine that improves flexibility, reduces stress, sharpens focus, and creates a lasting sense of calm and body awareness.',
    category: 'health_wellness',
    strategies: [
      {
        title: 'Establish a consistent daily meditation habit',
        description: 'Start small, build slowly, and anchor meditation to an existing daily routine so it sticks.',
        objectives: [
          {
            title: 'Meditate for at least 10 minutes every day for 60 consecutive days',
            description: 'Consistency matters far more than session length — 10 focused minutes daily rewires stress response more effectively than occasional long sits.',
            measures: 'Daily meditation log or app streak; 60 consecutive days of 10+ minute sessions',
            tactics: [
              {
                title: 'Choose a meditation style and set up your practice space',
                description: 'Picking one approach and creating a dedicated space removes friction and builds identity around the habit.',
                links: [{ title: 'Insight Timer App', url: 'https://insighttimer.com/' }, { title: 'Meditation Basics', url: 'https://www.psychologytoday.com/us/basics/meditation' }, { title: 'Mindfulness Meditation', url: 'https://www.mindful.org/meditation/' }],
                tasks: [
                  { title: 'Research beginner meditation styles: breath awareness, body scan, loving-kindness, mantra' },
                  { title: 'Choose a guided meditation app (Headspace, Calm, Insight Timer, or YouTube)' },
                  { title: 'Designate a quiet corner with a cushion, mat, or chair as your meditation spot' },
                  { title: 'Set a daily alarm for the same time each day (morning works best for most people)' },
                  { title: 'Start with 5 minutes for week 1, increase to 10 minutes in week 2, 15 in week 4' },
                ],
              },
              {
                title: 'Build accountability and track your progress',
                description: 'Tracking and reflecting on your practice strengthens motivation and reveals patterns.',
                links: [{ title: 'Recommended Resource', url: 'https://www.example.com/' }],
                tasks: [
                  { title: 'Use a habit tracker app or paper journal to log each session' },
                  { title: 'After each session, write one sentence about how you felt' },
                  { title: 'Review weekly: note any changes in stress, sleep, or focus' },
                  { title: 'Find an accountability partner or join an online meditation community' },
                ],
              },
            ],
          },
          {
            title: 'Deepen meditation insights through a structured practice journal and reflection',
            description: 'Journaling about your meditation experience consolidates learning and reveals patterns over time.',
            measures: 'Consistent journaling 4+ days per week; deepening insights documented over 60 days',
            tactics: [
              {
                title: 'Create a meditation journal to track insights and patterns',
                description: 'Meditation insights often emerge between sessions, not during them.',
                links: [{ title: 'Journaling for Meditation', url: 'https://www.mindful.org/meditation/' }],
                tasks: [
                  { title: 'After each session, write 3–5 sentences: What was I aware of? What challenged me? What was I grateful for?' },
                  { title: 'Note any emotions, sensations, or thoughts that arise — patterns reveal themselves over weeks' },
                  { title: 'Monthly, review your journal and note what\'s changed in your mind and body' },
                  { title: 'Share insights with an accountability partner or meditation group to deepen understanding' },
                ],
              },
              {
                title: 'Explore different meditation styles to deepen and expand the practice',
                description: 'Trying different techniques prevents staleness and reveals which methods work best for you.',
                tasks: [
                  { title: 'After 30 days of breath awareness practice, experiment with loving-kindness (metta) meditation for 2 weeks' },
                  { title: 'Try a body scan meditation before sleep for one week and compare sleep quality to baseline' },
                  { title: 'Attend a local or online meditation group session at least once to experience community practice' },
                ],
              },
            ],
          },
        ],
      },
      {
        title: 'Develop a regular yoga practice',
        description: 'Progress from foundational poses to a flowing practice that builds strength, flexibility, and breath-body awareness.',
        objectives: [
          {
            title: 'Complete 3 yoga sessions per week for 12 consecutive weeks',
            description: 'Three sessions per week is the minimum effective dose to see meaningful gains in flexibility, strength, and mental clarity.',
            measures: 'Session log (date, style, duration); before/after flexibility benchmarks (forward fold, hip opener, shoulder mobility)',
            tactics: [
              {
                title: 'Choose a yoga style and beginner program',
                description: 'Matching the style to your goal prevents frustration — Hatha for foundational alignment, Vinyasa for flow, Yin for deep flexibility and stress relief.',
                links: [{ title: 'Yoga for Beginners', url: 'https://www.yogajournal.com/yoga-101/' }, { title: 'Flexibility Training', url: 'https://www.acefitness.org/' }, { title: 'Stretching Routine', url: 'https://www.mayoclinic.org/healthy-lifestyle/fitness/in-depth/stretching/art-20047570' }],
                tasks: [
                  { title: 'Research beginner yoga styles: Hatha, Vinyasa, Yin, Restorative, Power' },
                  { title: 'Choose a structured beginner program: Yoga with Adriene 30 Days, DoYogaWithMe, or a local studio' },
                  { title: 'Buy or borrow a non-slip yoga mat, two blocks, and a strap' },
                  { title: 'Block 3 recurring calendar slots per week (e.g. Mon / Wed / Sat morning)' },
                  { title: 'Take baseline flexibility measurements: forward fold reach, pigeon pose depth, shoulder mobility' },
                ],
              },
              {
                title: 'Learn and master foundational yoga poses',
                description: 'A strong foundation in key poses prevents injury and accelerates progress in every style of yoga.',
                links: [{ title: 'Yoga for Beginners', url: 'https://www.yogajournal.com/yoga-101/' }, { title: 'Flexibility Training', url: 'https://www.acefitness.org/' }, { title: 'Stretching Routine', url: 'https://www.mayoclinic.org/healthy-lifestyle/fitness/in-depth/stretching/art-20047570' }],
                tasks: [
                  { title: 'Study the 10 foundational poses: Mountain, Downward Dog, Warrior I & II, Plank, Child\'s Pose, Bridge, Tree, Seated Forward Fold, Corpse' },
                  { title: 'Practice proper breathing technique (Ujjayi breath) for 5 minutes before each session' },
                  { title: 'Film yourself monthly in 3–4 key poses to compare alignment over time' },
                  { title: 'Identify your tightest areas (hips, hamstrings, shoulders) and add targeted 5-minute openers' },
                ],
              },
            ],
          },
          {
            title: 'Progress to intermediate yoga flows and build physical strength through advanced poses',
            description: 'After mastering foundations, challenge yourself with more dynamic flows that build real strength.',
            measures: 'Able to hold intermediate poses (arm balances, deep backbends) for full duration; advanced class participation',
            tactics: [
              {
                title: 'Move from beginner to intermediate yoga classes',
                description: 'Progress naturally when you can complete beginner flows without modification.',
                links: [{ title: 'Advanced Yoga Poses', url: 'https://www.yogajournal.com/yoga-101/' }],
                tasks: [
                  { title: 'After 12 weeks of consistent practice, take one intermediate class to assess readiness' },
                  { title: 'Choose 2–3 intermediate sequences (YouTube channels like Yoga with Adriene, DoYogaWithMe, or local studios)' },
                  { title: 'Practice arm balances (crow pose, side crow) and deeper backbends 1x per week' },
                  { title: 'Set a goal for an advanced pose: inversions (headstand, handstand) or advanced backbends' },
                ],
              },
              {
                title: 'Track strength and flexibility milestones to measure yoga progress objectively',
                description: 'Measurable progress benchmarks keep motivation high during the slower middle phase of development.',
                tasks: [
                  { title: 'Photograph or video yourself in 3 benchmark poses every 4 weeks to see alignment improvement' },
                  { title: 'Track flexibility gains: forward fold finger-to-floor distance, hip opener range, and shoulder mobility' },
                  { title: 'Note when you first achieve key milestones: holding crow for 5 breaths, full forward fold, wheel pose' },
                ],
              },
            ],
          },
        ],
      },
      {
        title: 'Integrate yoga and meditation into a unified mind-body routine',
        description: 'Once separate habits are established, weave them together into a flowing morning or evening ritual.',
        objectives: [
          {
            title: 'Maintain a combined yoga + meditation practice for 6 months',
            description: 'A unified practice deepens both disciplines — yoga prepares the body and nervous system for meditation, making both more effective.',
            measures: 'Bi-weekly check-in journal entries tracking energy, mood, flexibility, and stress levels over 6 months',
            tactics: [
              {
                title: 'Design a combined morning or evening ritual',
                description: 'Structure the session so yoga and meditation flow naturally together without friction.',
                links: [{ title: 'Recommended Resource', url: 'https://www.example.com/' }],
                tasks: [
                  { title: 'Experiment with two formats for 2 weeks each: yoga-first vs. meditation-first' },
                  { title: 'Settle on a structure: e.g. 20 min yoga flow → 10 min seated meditation → 5 min journaling' },
                  { title: 'Create a playlist or ambient soundscape to signal the start of the ritual' },
                  { title: 'Reduce phone notifications during your practice window' },
                ],
              },
              {
                title: 'Deepen your practice with learning and community',
                description: 'Going beyond basic instruction — through workshops, books, or community — accelerates growth and sustains motivation.',
                links: [{ title: 'Coursera Online Courses', url: 'https://www.coursera.org/' }, { title: 'Khan Academy Free Learning', url: 'https://www.khanacademy.org/' }, { title: 'Udemy Learning Platform', url: 'https://www.udemy.com/' }],
                tasks: [
                  { title: 'Read one book on yoga or meditation philosophy (e.g. "The Yoga Sutras," "Wherever You Go There You Are")' },
                  { title: 'Attend at least one in-person yoga class or workshop to get live instruction and feedback' },
                  { title: 'Explore a 10-day challenge or retreat (even virtual) to deepen focus' },
                  { title: 'Review your 6-month measurements and write a reflection on changes in flexibility, stress, and mindset' },
                ],
              },
            ],
          },
          {
            title: 'Sustain your yoga and meditation practice beyond 6 months with renewal and evolution',
            description: 'The goal is not perfection — it\'s building a lifelong practice that evolves with your needs.',
            measures: 'Continued practice 4+ days per week; annual participation in a yoga retreat or advanced training',
            tactics: [
              {
                title: 'Create a practice renewal plan to prevent burnout and staleness',
                description: 'Long-term practice requires periodic renewal and evolution.',
                links: [{ title: 'Sustaining Practice', url: 'https://www.yogajournal.com/yoga-101/' }],
                tasks: [
                  { title: 'Every 6 months, try a new yoga style (yin, power, vinyasa flow) or meditation approach to keep practice fresh' },
                  { title: 'Schedule an annual yoga retreat or intensive training to deepen and reinvigorate practice' },
                  { title: 'Connect with a yoga community (studio, online group, or retreat) to maintain motivation and accountability' },
                  { title: 'Set annual practice goals (e.g., master an arm balance, attend a 7-day silent retreat, learn pranayama)' },
                ],
              },
              {
                title: 'Teach or share your practice to cement learning and inspire others',
                description: 'Teaching others is the fastest way to deepen your own understanding of yoga and meditation.',
                tasks: [
                  { title: 'Lead a friend or family member through a beginner yoga session using what you\'ve learned' },
                  { title: 'Share your practice journey on social media or in a journal — public reflection reinforces commitment' },
                  { title: 'Explore a yoga teacher training (200-hour YTT) if you feel called to formalize and deepen your knowledge' },
                ],
              },
            ],
          },
        ],
      },
    ],
  },

  // ── Lose 10 Pounds ────────────────────────────────────────────────────────
  {
    id: 'hw_lose_10lbs',
    categoryId: 'health_wellness',
    title: 'Lose 10 Pounds',
    description: 'Shed 10 pounds in 10–12 weeks through a modest calorie deficit and increased daily movement — without extreme dieting.',
    category: 'health_wellness',
    strategies: [
      {
        title: 'Create a sustainable calorie deficit through smarter food choices',
        description: 'Reduce daily intake by 400–500 calories by improving food quality and portion awareness — not starvation.',
        objectives: [
          {
            title: 'Understand your current eating patterns and calorie baseline',
            description: 'You cannot fix what you do not measure. Build awareness before making changes.',
            measures: 'Food diary kept for 7 consecutive days; calorie baseline identified',
            tactics: [
              {
                title: 'Track every meal and drink for one full week',
                description: 'Use an app like MyFitnessPal or Cronometer to log everything without judgment.',
                links: [{ title: 'Meal Prep Ideas', url: 'https://www.eatthismuch.com/' }, { title: 'Harvard Nutrition Source', url: 'https://www.hsph.harvard.edu/nutritionsource/' }, { title: 'USDA MyPlate', url: 'https://www.myplate.gov/' }],
                tasks: [
                  { title: 'Download MyFitnessPal (free) and create an account' },
                  { title: 'Set your goal to "lose 1 lb per week" to auto-calculate your calorie target' },
                  { title: 'Log every meal, snack, drink, and condiment for 7 days straight' },
                  { title: 'Note your biggest calorie sources at end of week — identify the top 3' },
                  { title: 'Calculate your average daily calories from the week log' },
                ],
              },
              {
                title: 'Understand your personal hunger and fullness cues',
                description: 'Awareness of hunger signals prevents both deprivation and overeating.',
                links: [{ title: 'Hunger Awareness', url: 'https://www.hsph.harvard.edu/nutritionsource/' }],
                tasks: [
                  { title: 'Rate your hunger level (1–10) before each meal for one week' },
                  { title: 'Notice: Are you eating when truly hungry or due to habit, stress, or boredom?' },
                  { title: 'Identify your personal satiety signals — when do you feel satisfied vs. stuffed' },
                  { title: 'Create a rule: Only eat when hunger is at 5 or below, stop when 80% full' },
                ],
              },
            ],
          },
          {
            title: 'Reduce daily calories by 400–500 without feeling deprived',
            description: 'Small, painless swaps add up to a pound a week without misery.',
            measures: 'Average daily calories at or below target for 8 consecutive weeks',
            tactics: [
              {
                title: 'Swap high-calorie staples for lower-calorie alternatives',
                description: 'Keep eating foods you enjoy — just swap smarter versions.',
                links: [{ title: 'Recommended Resource', url: 'https://www.example.com/' }],
                tasks: [
                  { title: 'Switch from regular soda to sparkling water or diet soda (saves 140+ cal/day)' },
                  { title: 'Use a smaller plate at dinner — visual portions reduce intake 15–20%' },
                  { title: 'Replace full-fat dressings and sauces with lighter versions or use half portions' },
                  { title: 'Pre-portion snacks into individual servings — never eat directly from the bag' },
                  { title: 'Stop eating 2–3 hours before bed to eliminate mindless late-night calories' },
                ],
              },
              {
                title: 'Increase protein and fiber intake to stay fuller longer',
                description: 'Protein and fiber reduce hunger and protect muscle during weight loss.',
                links: [{ title: 'Recommended Resource', url: 'https://www.example.com/' }],
                tasks: [
                  { title: 'Add a protein source to every meal (eggs, Greek yogurt, chicken, beans, cottage cheese)' },
                  { title: 'Eat a large vegetable serving first at dinner before any other food' },
                  { title: 'Choose high-fiber bread, pasta, and grains over white/refined versions' },
                  { title: 'Have a protein-rich snack mid-afternoon to prevent dinner overeating' },
                ],
              },
            ],
          },
          {
            title: 'Eliminate liquid calories and improve hydration',
            description: 'Drinks are the sneakiest source of hidden calories.',
            measures: 'Drink at least 64 oz water per day; alcohol limited to ≤2 drinks per week',
            tactics: [
              {
                title: 'Replace caloric beverages with water and zero-calorie drinks',
                description: 'Alcohol, juice, and specialty coffees can add 300–600 calories daily without noticing.',
                links: [{ title: 'Hydration Importance', url: 'https://www.mayoclinic.org/healthy-lifestyle/nutrition-and-healthy-eating/in-depth/water/art-20044256' }, { title: 'Harvard: Water Benefits', url: 'https://www.health.harvard.edu/nutrition/the-truth-about-hydration' }],
                tasks: [
                  { title: 'Carry a 32 oz water bottle and refill it twice daily' },
                  { title: 'Replace juice at breakfast with whole fruit (more fiber, fewer calories)' },
                  { title: 'Order plain coffee or tea instead of specialty lattes and blended drinks' },
                  { title: 'Set a drink limit for weekends (max 2 alcoholic drinks per week during the 10-week push)' },
                ],
              },
              {
                title: 'Create accountability for beverage choices and track liquid calorie intake',
                description: 'Awareness of hidden liquid calories is the fastest way to spot the biggest leaks in your deficit.',
                links: [{ title: 'Calorie Awareness', url: 'https://www.eatthismuch.com/' }],
                tasks: [
                  { title: 'Log all beverages in MyFitnessPal for the first 4 weeks (alcohol, coffee drinks, juice, smoothies)' },
                  { title: 'Identify which beverages contain the most hidden calories' },
                  { title: 'Take a "before" photo of what you typically drink in a day and compare to "after" after eliminating liquid calories' },
                  { title: 'Share your beverage swap progress with an accountability partner weekly' },
                ],
              },
            ],
          },
        ],
      },
      {
        title: 'Increase daily movement and light exercise to burn extra calories',
        description: 'You do not need a gym membership. Consistent daily movement accelerates the deficit and improves energy.',
        objectives: [
          {
            title: 'Hit 8,000+ steps per day consistently',
            description: 'Walking is the most underrated fat-loss tool — low injury risk, no equipment, no gym.',
            measures: 'Step count logged daily; average ≥8,000 steps/day over any 4-week period',
            tactics: [
              {
                title: 'Build walking into your existing daily routine',
                description: 'Habit-stack walking onto things you already do.',
                links: [{ title: 'Atomic Habits', url: 'https://jamesclear.com/atomic-habits' }, { title: 'Habitica Habit Tracker', url: 'https://www.habitica.com/' }, { title: 'BJ Fogg Behavior Model', url: 'https://www.behaviormodel.org/' }],
                tasks: [
                  { title: 'Enable the step counter on your phone or buy a cheap fitness tracker' },
                  { title: 'Park farther from entrances everywhere you go — adds 500–1,000 steps/trip' },
                  { title: 'Take a 15-minute walk after dinner every night — burns ~75 cal, improves sleep' },
                  { title: 'Take the stairs instead of elevator or escalator every time' },
                  { title: 'Walk during phone calls instead of sitting' },
                ],
              },
              {
                title: 'Use step challenges and competitions to boost daily activity',
                description: 'Friendly competition and social accountability make step goals more engaging.',
                links: [{ title: 'Activity Challenges', url: 'https://www.fitbit.com/' }, { title: 'Social Motivation', url: 'https://www.habitica.com/' }],
                tasks: [
                  { title: 'Join a free step challenge: Fitbit challenges, StepBet, or compete with friends' },
                  { title: 'Share your step count with an accountability partner or group chat — weekly updates' },
                  { title: 'Set mini-milestones: 6,000 steps by week 2, 7,000 by week 4, 8,000 by week 6' },
                  { title: 'Celebrate reaching daily targets with a non-food reward' },
                ],
              },
            ],
          },
          {
            title: 'Add 2–3 structured exercise sessions per week',
            description: 'Brief intentional workouts accelerate fat loss and boost metabolism for hours afterward.',
            measures: 'At least 2 workouts per week for 8 consecutive weeks',
            tactics: [
              {
                title: 'Start a simple 30-minute beginner workout routine',
                description: 'Bodyweight exercises at home or basic gym work — nothing complicated needed.',
                links: [{ title: 'Atomic Habits', url: 'https://jamesclear.com/atomic-habits' }, { title: 'Habitica Habit Tracker', url: 'https://www.habitica.com/' }, { title: 'BJ Fogg Behavior Model', url: 'https://www.behaviormodel.org/' }],
                tasks: [
                  { title: 'Choose a workout format: home bodyweight, gym machines, swimming, or cycling' },
                  { title: 'Schedule 2–3 workout sessions per week in your calendar as non-negotiable blocks' },
                  { title: 'Complete a 30-minute beginner workout: 10 squats, 10 push-ups, 20 lunges, 30-sec plank × 3 sets' },
                  { title: 'Increase duration or difficulty by 5–10% each week as fitness improves' },
                  { title: 'Log every workout — even bad ones count; consistency beats perfection' },
                ],
              },
              {
                title: 'Make workouts enjoyable through music, entertainment, or social connection',
                description: 'Workouts you enjoy are workouts you\'ll actually do consistently.',
                links: [{ title: 'Motivation & Fitness', url: 'https://www.habitica.com/' }],
                tasks: [
                  { title: 'Create a high-energy workout playlist (120+ bpm) to keep motivation up' },
                  { title: 'Watch shows, podcasts, or videos during cardio to make time fly' },
                  { title: 'Invite a friend to join workouts 1–2 times per week for accountability and fun' },
                  { title: 'Track your favorite workout — do more of what you actually enjoy' },
                ],
              },
            ],
          },
        ],
      },
      {
        title: 'Build accountability and track weekly progress',
        description: 'What gets measured gets managed. Consistent tracking predicts success.',
        objectives: [
          {
            title: 'Weigh in weekly and track the trend — not daily fluctuations',
            description: 'Weight fluctuates 2–4 lbs day to day from water and food. The trend line over weeks is what matters.',
            measures: 'Weekly weigh-in logged every Monday morning; 10 lbs lost within 12 weeks',
            tactics: [
              {
                title: 'Set up a simple weekly weigh-in ritual',
                description: 'Same time, same conditions, every week.',
                links: [{ title: 'Recommended Resource', url: 'https://www.example.com/' }],
                tasks: [
                  { title: 'Weigh yourself every Monday morning, before eating, after bathroom' },
                  { title: 'Log weight in a note, spreadsheet, or app — do not rely on memory' },
                  { title: 'Take a progress photo from the front and side on Week 1 and Week 12' },
                  { title: 'Set a mini-reward for yourself at the 5 lb milestone (non-food reward)' },
                  { title: 'Review your week every Sunday — what went well? What is one thing to improve?' },
                ],
              },
              {
                title: 'Use multiple metrics beyond the scale to measure progress',
                description: 'The scale is just one data point. Strength, energy, and measurements tell a richer story.',
                links: [{ title: 'Progress Measurement', url: 'https://www.myfitnesspal.com/' }],
                tasks: [
                  { title: 'Measure your body: waist, hip, chest, arm, thigh at Week 1 and Week 12' },
                  { title: 'Track how clothes fit — do your jeans feel looser? Can you button that shirt?' },
                  { title: 'Note energy levels, sleep quality, and mood improvements alongside weight changes' },
                  { title: 'Track a fitness metric: how many push-ups, plank duration, or time to walk a mile' },
                ],
              },
            ],
          },
          {
            title: 'Anticipate and prepare for challenges and setbacks',
            description: 'Most 10-lb goals fail because of unplanned obstacles. Planning prevents derailment.',
            measures: 'Challenge plan created for 3+ potential obstacles; successfully navigated at least 1 setback',
            tactics: [
              {
                title: 'Create a challenge roadmap and preparation plan',
                description: 'Expect obstacles and have a response plan ready.',
                links: [{ title: 'Resilience Planning', url: 'https://jamesclear.com/atomic-habits' }],
                tasks: [
                  { title: 'List 3 likely obstacles: social events, travel, stress eating, plateaus, lost motivation' },
                  { title: 'For each obstacle, write a specific action plan (e.g., "If I go to a party, I will eat dinner first, have 1 alcoholic drink, and bring a healthy side dish")' },
                  { title: 'Identify your personal "emergency protocol" — what will you do if you slip for a meal or a day' },
                  { title: 'Remember: one meal does not ruin a 10-week goal — the next meal is your chance to get back on track' },
                ],
              },
              {
                title: 'Build an accountability system to maintain momentum through the full 12 weeks',
                description: 'External accountability dramatically increases follow-through on weight loss goals.',
                tasks: [
                  { title: 'Tell one supportive friend or family member your goal and target date — make it real' },
                  { title: 'Check in with your accountability person weekly — share your weigh-in and one win from the week' },
                  { title: 'Join an online community (Reddit r/loseit, MyFitnessPal groups, or a Discord) for peer support' },
                ],
              },
            ],
          },
        ],
      },
    ],
  },

  // ── Lose 20 Pounds ────────────────────────────────────────────────────────
  {
    id: 'hw_lose_20lbs',
    categoryId: 'health_wellness',
    title: 'Lose 20 Pounds',
    description: 'Lose 20 pounds in 5–6 months with a structured nutrition plan, consistent exercise, and habit systems that keep you on track.',
    category: 'health_wellness',
    strategies: [
      {
        title: 'Overhaul nutrition with a structured, flexible eating plan',
        description: 'Sustainable 500-calorie daily deficit through meal planning, smart choices, and understanding your body.',
        objectives: [
          {
            title: 'Calculate and consistently hit your daily calorie and protein target',
            description: 'Precision matters more at 20 lbs. Hitting protein prevents muscle loss during the longer deficit.',
            measures: 'Daily calories within 100 cal of target; protein ≥0.7g per pound of bodyweight; tracked for 8 weeks',
            tactics: [
              {
                title: 'Set up a personalized nutrition plan',
                description: 'Use science-based targets, not guesswork.',
                links: [{ title: 'Meal Prep Ideas', url: 'https://www.eatthismuch.com/' }, { title: 'Harvard Nutrition Source', url: 'https://www.hsph.harvard.edu/nutritionsource/' }, { title: 'USDA MyPlate', url: 'https://www.myplate.gov/' }],
                tasks: [
                  { title: 'Calculate TDEE (Total Daily Energy Expenditure) at tdee.calculator.net' },
                  { title: 'Set calorie target at TDEE minus 500 (equals ~1 lb/week loss rate)' },
                  { title: 'Set protein target: body weight in lbs × 0.7 = daily protein grams' },
                  { title: 'Set up MyFitnessPal with custom calorie and protein goals' },
                  { title: 'Log food for at least the first 8 weeks until portion sense is calibrated' },
                ],
              },
              {
                title: 'Meal prep 2x per week to eliminate decision fatigue',
                description: 'Most diet failures happen because healthy food is not ready when hunger hits.',
                links: [{ title: 'Meal Prep Ideas', url: 'https://www.eatthismuch.com/' }, { title: 'Harvard Nutrition Source', url: 'https://www.hsph.harvard.edu/nutritionsource/' }, { title: 'USDA MyPlate', url: 'https://www.myplate.gov/' }],
                tasks: [
                  { title: 'Choose a Sunday + Wednesday as your two weekly meal prep sessions' },
                  { title: 'Prep 4–5 high-protein, lower-calorie lunches per batch (chicken + veg + grain)' },
                  { title: 'Batch-cook breakfast options: boiled eggs, overnight oats, or egg muffins' },
                  { title: 'Pre-cut and store snack vegetables (carrots, celery, bell pepper) for easy access' },
                  { title: 'Plan your dinners for the week every Sunday — grocery shop with a list, not impulse' },
                ],
              },
            ],
          },
          {
            title: 'Develop consistent, healthy eating habits that replace old patterns',
            description: 'Habits run on autopilot; build the right ones and the weight takes care of itself.',
            measures: 'Three new eating habits maintained for 30+ consecutive days each',
            tactics: [
              {
                title: 'Implement the hunger-and-fullness protocol',
                description: 'Learn to eat for hunger, not emotion or boredom.',
                links: [{ title: 'Recommended Resource', url: 'https://www.example.com/' }],
                tasks: [
                  { title: 'Before every meal, rate your hunger on a 1–10 scale — only eat when at 5 or below' },
                  { title: 'Put your fork down between bites and eat slowly — aim for 20 minutes per meal' },
                  { title: 'Stop eating when you feel 80% full — not when the plate is empty' },
                  { title: 'Identify your top 3 emotional eating triggers and write a non-food response for each' },
                ],
              },
              {
                title: 'Build restaurant and social eating strategies',
                description: 'Eating out and social events cannot derail a 20-lb goal.',
                links: [{ title: 'Sleep Hygiene', url: 'https://www.cdc.gov/sleep/about_sleep/sleep-hygiene.html' }, { title: 'Harvard Sleep Medicine', url: 'https://sleep.hms.harvard.edu/' }, { title: 'Better Sleep Tips', url: 'https://www.mayoclinic.org/healthy-lifestyle/adult-health/in-depth/sleep/art-20048379' }],
                tasks: [
                  { title: 'Check the restaurant menu before arriving and pre-decide your order' },
                  { title: 'Request dressings and sauces on the side — use half or less' },
                  { title: 'Order a side salad or soup first to reduce how much of the main you eat' },
                  { title: 'Allow yourself one planned "flex meal" per week — enjoy it without guilt' },
                  { title: 'Never go to a restaurant or party starving — eat a protein snack first' },
                ],
              },
            ],
          },
        ],
      },
      {
        title: 'Build a consistent 4x-per-week exercise habit',
        description: 'Structured exercise preserves muscle, accelerates fat loss, and dramatically improves overall health and mood.',
        objectives: [
          {
            title: 'Complete at least 150 minutes of moderate exercise per week',
            description: 'The combination of cardio and strength training produces the best fat-loss results.',
            measures: 'Weekly exercise minutes logged; ≥150 min for 10+ consecutive weeks',
            tactics: [
              {
                title: 'Follow a structured cardio plan 2–3 times per week',
                description: 'Cardio creates the calorie burn; start manageable and build.',
                links: [{ title: 'CDC Physical Activity Guidelines', url: 'https://www.cdc.gov/physicalactivity/basics/index.html' }, { title: 'Harvard: Cardiovascular Health', url: 'https://www.health.harvard.edu/heart-health' }, { title: 'Heart Rate Monitoring', url: 'https://www.mayoclinic.org/healthy-lifestyle/fitness/expert-answers/heart-rate/faq-20057979' }],
                tasks: [
                  { title: 'Choose your primary cardio: walking/jogging, cycling, swimming, or elliptical' },
                  { title: 'Week 1–2: 25 minutes, moderate pace, 2x per week' },
                  { title: 'Week 3–4: 30 minutes, 3x per week — add one interval session (1 min fast / 2 min easy)' },
                  { title: 'Week 5+: 35–45 minutes, 3x per week with one harder interval session' },
                  { title: 'Log every cardio session — date, type, duration, perceived effort' },
                ],
              },
              {
                title: 'Add strength training 2x per week to preserve muscle',
                description: 'Muscle burns more calories at rest. Strength training prevents the "skinny fat" outcome of cardio-only weight loss.',
                links: [{ title: 'StrongLifts 5x5', url: 'https://stronglifts.com/' }, { title: 'Proper Lifting Form', url: 'https://www.mayoclinic.org/healthy-lifestyle/fitness/in-depth/strength-training/art-20046670' }, { title: 'Starting Strength Program', url: 'https://www.startingstrength.com/' }],
                tasks: [
                  { title: 'Follow a simple beginner full-body routine: squat, hinge, push, pull, carry' },
                  { title: 'Week 1–4: 2 sets of 10–12 reps; prioritize learning form over heavy weight' },
                  { title: 'Week 5+: 3 sets; add weight when you can do all reps with good form' },
                  { title: 'Schedule strength sessions on non-consecutive days (e.g. Monday + Thursday)' },
                  { title: 'Consider 2–3 sessions with a personal trainer to learn safe form on key exercises' },
                ],
              },
            ],
          },
          {
            title: 'Increase non-exercise activity to 10,000 steps/day',
            description: 'NEAT (non-exercise activity thermogenesis) accounts for up to 30% of daily calorie burn.',
            measures: 'Daily step average ≥10,000 tracked via phone or wearable for 8+ weeks',
            tactics: [
              {
                title: 'Systematically add steps to daily life',
                description: 'Stack movement onto existing habits to hit the step goal without "trying."',
                links: [{ title: 'Recommended Resource', url: 'https://www.example.com/' }],
                tasks: [
                  { title: 'Enable step tracking on phone or purchase a fitness tracker' },
                  { title: 'Walk during every phone call, meeting, or podcast — pace instead of sit' },
                  { title: 'Add a 20-minute post-dinner walk 5 nights per week' },
                  { title: 'Take a 5-minute walk break every hour of desk work (set a timer)' },
                  { title: 'Review step count each evening — if below 8,000, take a short walk before bed' },
                ],
              },
              {
                title: 'Leverage technology and social motivation for sustained step achievement',
                description: 'Gamification and social support make hitting 10,000 steps more engaging.',
                links: [{ title: 'Activity Tracking', url: 'https://www.fitbit.com/' }],
                tasks: [
                  { title: 'Set up a weekly step challenge with friends or family using Fitbit, Apple Health, or Stepbet' },
                  { title: 'Join an online community focused on daily steps or walking (Reddit, StepBet, or local walking groups)' },
                  { title: 'Use your step tracker\'s challenge feature to gamify goals' },
                  { title: 'Create a "step jar" reward system: for every 50,000 steps, earn a small non-food reward' },
                ],
              },
            ],
          },
        ],
      },
      {
        title: 'Create accountability systems and manage the mental game',
        description: 'Losing 20 lbs takes 5+ months. Mindset, accountability, and adaptation skills determine whether you finish.',
        objectives: [
          {
            title: 'Establish weekly review and adjustment rituals',
            description: 'Review → learn → adjust is the engine of sustained progress.',
            measures: 'Weekly review completed every week; plan adjusted at least once based on data',
            tactics: [
              {
                title: 'Conduct a weekly 15-minute progress review',
                description: 'Treat your goal like a project — review the data and make next-week decisions.',
                links: [{ title: 'Recommended Resource', url: 'https://www.example.com/' }],
                tasks: [
                  { title: 'Weigh in every Monday morning — same time, before eating, after bathroom' },
                  { title: 'Log weekly weight in a trend tracker (app, spreadsheet, or journal)' },
                  { title: 'Review last week: average calories, workout count, and step average' },
                  { title: 'Identify one win from the week and one thing to improve next week' },
                  { title: 'Take monthly progress photos (front, side) — the scale lies, photos do not' },
                ],
              },
              {
                title: 'Build a support and accountability structure',
                description: 'External accountability dramatically increases success rates on long-term goals.',
                links: [{ title: 'Recommended Resource', url: 'https://www.example.com/' }],
                tasks: [
                  { title: 'Tell at least one person your goal and target date — make it real' },
                  { title: 'Find an accountability partner (friend, family member, or online group) to check in weekly' },
                  { title: 'Set 5-lb milestone rewards (non-food): massage, new clothing, experience, etc.' },
                  { title: 'Plan a "what I will do when I plateau" strategy — reduce calories by 100 or add one cardio session' },
                  { title: 'Re-read your "why" statement for losing weight every Monday morning' },
                ],
              },
            ],
          },
          {
            title: 'Develop resilience and a long-term maintenance mindset',
            description: 'Losing 20 lbs is an achievement — keeping it off is the real goal. Build maintenance habits alongside weight-loss habits.',
            measures: 'Maintenance mindset practices in place by Month 4; weight regain under 2 lbs for 8 weeks after goal reached',
            tactics: [
              {
                title: 'Start practicing maintenance behaviors before reaching your goal weight',
                description: 'The transition from deficit to maintenance is smoother when you\'ve been practicing it all along.',
                tasks: [
                  { title: 'Every 4 weeks, take a "maintenance week" where you eat at your TDEE (not a deficit) — practice without losing the habit' },
                  { title: 'Choose a maintenance weight range (±3 lbs of goal) rather than a single number — it\'s more sustainable' },
                  { title: 'Identify which habits from this journey you want to keep forever vs. which were just for the weight-loss phase' },
                ],
              },
              {
                title: 'Address the psychological transition from weight loss to maintenance mode',
                description: 'Many people struggle psychologically when they shift from "losing" to "maintaining" — address this proactively.',
                tasks: [
                  { title: 'Write a "maintenance identity statement" — who are you now that you\'ve built these health habits?' },
                  { title: 'Set a new performance or fitness goal (5K, strength benchmark, flexibility milestone) to maintain motivation' },
                  { title: 'Schedule a monthly weigh-in for 12 months after reaching goal to ensure maintenance accountability' },
                ],
              },
            ],
          },
        ],
      },
    ],
  },

  // ── Lose 50 Pounds ────────────────────────────────────────────────────────
  {
    id: 'hw_lose_50lbs',
    categoryId: 'health_wellness',
    title: 'Lose 50 Pounds',
    description: 'A comprehensive 12–14 month transformation plan to lose 50 pounds through sustainable nutrition, progressive exercise, and lifestyle change.',
    category: 'health_wellness',
    strategies: [
      {
        title: 'Transform nutrition with a sustainable, long-term eating framework',
        description: 'At 50 lbs, this is a lifestyle overhaul — not a diet. Build an eating system you can maintain for life, not just until the weight is gone.',
        objectives: [
          {
            title: 'Understand your current baseline and establish a realistic calorie target',
            description: 'At a higher starting weight, the deficit math is more forgiving — you burn more at rest. Set realistic expectations.',
            measures: 'Calorie baseline established; target set at 600–750 cal deficit/day for ~1.5 lbs/week',
            tactics: [
              {
                title: 'Conduct a two-week food audit',
                description: 'Log everything without changing anything first — identify the true picture.',
                links: [{ title: 'Meal Prep Ideas', url: 'https://www.eatthismuch.com/' }, { title: 'Harvard Nutrition Source', url: 'https://www.hsph.harvard.edu/nutritionsource/' }, { title: 'USDA MyPlate', url: 'https://www.myplate.gov/' }],
                tasks: [
                  { title: 'Download Cronometer or MyFitnessPal and log every meal, drink, and snack for 14 days' },
                  { title: 'Calculate average daily calories and identify the top 5 calorie contributors' },
                  { title: 'Identify your 3 highest-risk situations for overeating (stress, boredom, social events, time of day)' },
                  { title: 'Use TDEE calculator to find your maintenance calories — set deficit target at 600–750 below' },
                  { title: 'Schedule a check-in with your doctor before beginning — discuss any health conditions and get baseline bloodwork' },
                ],
              },
              {
                title: 'Set realistic rate-of-loss expectations and adjust your calorie target',
                description: 'Sustainable loss is 1–1.5 lbs per week. Faster is not better when you have 50 lbs to go.',
                links: [{ title: 'Meal Prep Ideas', url: 'https://www.eatthismuch.com/' }, { title: 'Harvard Nutrition Source', url: 'https://www.hsph.harvard.edu/nutritionsource/' }, { title: 'USDA MyPlate', url: 'https://www.myplate.gov/' }],
                tasks: [
                  { title: 'Use your food audit data to set an initial daily calorie target (TDEE minus 600–750 cal)' },
                  { title: 'Enter your target into MyFitnessPal or Cronometer as a daily budget' },
                  { title: 'Set a weight-loss rate goal of 1–1.5 lbs per week — faster leads to muscle loss and burnout' },
                  { title: 'Plan to reassess calorie target every 6 weeks as your body weight and metabolism change' },
                  { title: 'Identify 3 high-calorie foods you eat regularly and research lower-calorie swaps for each' },
                ],
              },
            ],
          },
          {
            title: 'Build a protein-first, high-fiber eating pattern that controls hunger',
            description: 'Hunger is the enemy of a long diet. Protein and fiber are the solution.',
            measures: 'Protein intake ≥100g/day; fiber ≥30g/day; maintained for 12+ consecutive weeks',
            tactics: [
              {
                title: 'Redesign your meals around protein and fiber anchors',
                description: 'Every meal gets a protein anchor and a vegetable. Build from there.',
                links: [{ title: 'Meal Prep Ideas', url: 'https://www.eatthismuch.com/' }, { title: 'Harvard Nutrition Source', url: 'https://www.hsph.harvard.edu/nutritionsource/' }, { title: 'USDA MyPlate', url: 'https://www.myplate.gov/' }],
                tasks: [
                  { title: 'List 5 high-protein breakfast options you enjoy (eggs, Greek yogurt, cottage cheese, protein shakes, turkey)' },
                  { title: 'List 5 high-protein lunch options (chicken salad, tuna wrap, bean bowls, lentil soup)' },
                  { title: 'Fill half of every dinner plate with non-starchy vegetables before adding protein and carbs' },
                  { title: 'Identify 3 protein-rich snacks for hunger emergencies (jerky, string cheese, boiled eggs, edamame)' },
                  { title: 'Eliminate or drastically reduce ultra-processed foods — cook at home 5+ nights per week' },
                ],
              },
              {
                title: 'Master meal prep to make healthy eating the path of least resistance',
                description: 'At 12+ months, prep is not optional — it is the system that keeps you going.',
                links: [{ title: 'Meal Prep Ideas', url: 'https://www.eatthismuch.com/' }, { title: 'Harvard Nutrition Source', url: 'https://www.hsph.harvard.edu/nutritionsource/' }, { title: 'USDA MyPlate', url: 'https://www.myplate.gov/' }],
                tasks: [
                  { title: 'Choose Sunday as your primary meal prep day — block 2 hours on the calendar' },
                  { title: 'Batch cook a protein source (chicken breasts, ground turkey, hard-boiled eggs) every week' },
                  { title: 'Prep 5 grab-and-go lunches each Sunday for the work week' },
                  { title: 'Stock a "quick healthy dinner" pantry: canned fish, beans, frozen veg, brown rice pouches' },
                  { title: 'Write a weekly dinner plan every Sunday and grocery shop with only the list' },
                  { title: 'Cook double portions at dinner 3x per week — next-day lunch is already done' },
                ],
              },
            ],
          },
          {
            title: 'Identify and repair the habits and triggers that caused weight gain',
            description: 'Without addressing root causes, the weight comes back. This is the work most people skip.',
            measures: 'Three root-cause habits identified and replaced with healthy alternatives; 60-day streak on each',
            tactics: [
              {
                title: 'Map your personal overeating triggers and build response plans',
                description: 'The food is rarely the problem — the trigger is.',
                links: [{ title: 'Recommended Resource', url: 'https://www.example.com/' }],
                tasks: [
                  { title: 'Keep a trigger journal for 2 weeks: whenever you overeat, write what happened just before' },
                  { title: 'Identify your top 3 emotional triggers (stress, boredom, loneliness, celebration, etc.)' },
                  { title: 'Write a specific non-food response for each trigger (call a friend, take a walk, do 10 pushups)' },
                  { title: 'Remove high-risk foods from the home — if it is not there, you cannot eat it at 10pm' },
                  { title: 'Consider 4–6 sessions with a therapist or health coach to work on emotional eating' },
                ],
              },
              {
                title: 'Replace destructive food habits with sustainable healthy defaults',
                description: 'Every bad habit has a cue-routine-reward loop. Intercept the routine with a healthier one.',
                links: [{ title: 'Atomic Habits', url: 'https://jamesclear.com/atomic-habits' }, { title: 'Habitica Habit Tracker', url: 'https://www.habitica.com/' }, { title: 'BJ Fogg Behavior Model', url: 'https://www.behaviormodel.org/' }],
                tasks: [
                  { title: 'Identify your 3 most consistent bad food habits (late-night snacking, drive-thru lunches, weekend binges)' },
                  { title: 'Design a specific replacement behavior for each habit with the same reward feeling' },
                  { title: 'Use the "2-minute rule" — shrink the healthy replacement habit to 2 minutes to reduce resistance' },
                  { title: 'Put healthy foods at eye level in the fridge and pantry; put unhealthy foods out of sight or out of the house' },
                  { title: 'Track habit streaks using a simple paper calendar or habit-tracking app for 30 days minimum' },
                ],
              },
            ],
          },
        ],
      },
      {
        title: 'Build a progressive exercise program from foundation to strength',
        description: 'Exercise alone will not create 50 lbs of loss — but it will preserve muscle, double the speed, dramatically improve health, and keep weight off long-term.',
        objectives: [
          {
            title: 'Establish a sustainable walking and low-impact cardio foundation (Months 1–3)',
            description: 'Start where you are — not where you think you should be. Injury in Month 2 ends the journey.',
            measures: 'Daily steps averaging 8,000+; 3x/week structured movement session completed for 10+ weeks',
            tactics: [
              {
                title: 'Begin with daily walking as the primary exercise',
                description: 'Walking is joint-friendly, effective, and can be done anywhere. It is the single best starting exercise for significant weight loss.',
                links: [{ title: 'Recommended Resource', url: 'https://www.example.com/' }],
                tasks: [
                  { title: 'Enable step counter on phone or buy an inexpensive pedometer/fitness tracker' },
                  { title: 'Week 1: aim for 5,000 steps/day — record your current baseline first' },
                  { title: 'Add 500 steps per week until you consistently hit 8,000–10,000/day' },
                  { title: 'Schedule 3 dedicated 20–30 minute walks per week (morning, lunch, or evening)' },
                  { title: 'Find a walking partner or walking podcast to make it enjoyable and consistent' },
                ],
              },
              {
                title: 'Add low-impact cardio sessions 2–3x per week',
                description: 'Swimming, cycling, elliptical, and water aerobics are ideal at higher body weights — low joint stress, high calorie burn.',
                links: [{ title: 'CDC Physical Activity Guidelines', url: 'https://www.cdc.gov/physicalactivity/basics/index.html' }, { title: 'Harvard: Cardiovascular Health', url: 'https://www.health.harvard.edu/heart-health' }, { title: 'Heart Rate Monitoring', url: 'https://www.mayoclinic.org/healthy-lifestyle/fitness/expert-answers/heart-rate/faq-20057979' }],
                tasks: [
                  { title: 'Choose your low-impact cardio mode: pool swimming, recumbent bike, or elliptical' },
                  { title: 'Start with 20 minutes, moderate effort, 2x per week in Month 1' },
                  { title: 'Build to 30–40 minutes, 3x per week by Month 2' },
                  { title: 'Add one interval session per week in Month 3 (30 sec harder / 90 sec easy × 8 rounds)' },
                  { title: 'Log every session: date, type, duration, and how you felt' },
                ],
              },
            ],
          },
          {
            title: 'Introduce progressive strength training (Months 3–6)',
            description: 'Strength training preserves muscle during a large deficit and revs the metabolism. Delay it slightly to first build a movement base.',
            measures: 'Strength training 2x/week completed for 12+ consecutive weeks; measurable strength gains in all major movements',
            tactics: [
              {
                title: 'Begin a beginner full-body strength program',
                description: 'Machines are ideal for beginners — lower injury risk, easier to learn, effective.',
                links: [{ title: 'StrongLifts 5x5', url: 'https://stronglifts.com/' }, { title: 'Proper Lifting Form', url: 'https://www.mayoclinic.org/healthy-lifestyle/fitness/in-depth/strength-training/art-20046670' }, { title: 'Starting Strength Program', url: 'https://www.startingstrength.com/' }],
                tasks: [
                  { title: 'Join a gym or purchase resistance bands and a set of dumbbells for home' },
                  { title: 'Follow a structured beginner program: StrongLifts 5×5, Greyskull LP, or a beginner machine circuit' },
                  { title: 'Start with very light weight — learn the movement patterns before adding load' },
                  { title: 'Train 2x/week (Mon + Thu or Tue + Fri) for the first 8 weeks' },
                  { title: 'Add a third strength session per week in Month 5 once routine is solid' },
                  { title: 'Consider 2–4 sessions with a personal trainer to learn safe barbell and machine technique' },
                ],
              },
              {
                title: 'Track strength progress and increase load progressively',
                description: 'Progressive overload is the principle that drives muscle building — add a little more challenge every session.',
                links: [{ title: 'StrongLifts 5x5', url: 'https://stronglifts.com/' }, { title: 'Proper Lifting Form', url: 'https://www.mayoclinic.org/healthy-lifestyle/fitness/in-depth/strength-training/art-20046670' }, { title: 'Starting Strength Program', url: 'https://www.startingstrength.com/' }],
                tasks: [
                  { title: 'Log every workout: exercises, sets, reps, and weight used' },
                  { title: 'Add 2.5–5 lbs to each lift when you complete all reps with good form for 2 sessions in a row' },
                  { title: 'Take monthly photos to track body recomposition — the scale may not move but your shape will change' },
                  { title: 'Set 3-month strength benchmarks (e.g., squat 1× bodyweight, push-up 15 reps) and track progress' },
                  { title: 'Schedule a deload week every 6–8 weeks — reduce weight 40% and let your body recover' },
                ],
              },
            ],
          },
          {
            title: 'Progress to a full integrated fitness routine (Months 6–12+)',
            description: 'By Month 6, fitness is a habit. Now optimize it to continue losing and to build the body you want.',
            measures: 'Cardio 3x/week + strength 3x/week maintained; physical fitness metrics improving quarter over quarter',
            tactics: [
              {
                title: 'Combine cardio and strength into a 5–6 day per week training schedule',
                description: 'At this stage, exercise is part of your identity — not a chore.',
                links: [{ title: 'StrongLifts 5x5', url: 'https://stronglifts.com/' }, { title: 'Proper Lifting Form', url: 'https://www.mayoclinic.org/healthy-lifestyle/fitness/in-depth/strength-training/art-20046670' }, { title: 'Starting Strength Program', url: 'https://www.startingstrength.com/' }],
                tasks: [
                  { title: 'Structure 3 strength days + 2 cardio days + 1 active recovery (yoga, long walk, swim)' },
                  { title: 'Shift at least one cardio session to HIIT format: 20 minutes high-intensity intervals' },
                  { title: 'Set a fitness milestone goal for Month 9 (run a 5K, swim 1 mile, deadlift your bodyweight)' },
                  { title: 'Join a fitness class, sports league, or outdoor group to keep exercise social and fun' },
                  { title: 'Retest fitness benchmarks (resting heart rate, strength lifts, step capacity) quarterly' },
                ],
              },
              {
                title: 'Add a sport, recreational activity, or fitness community to maintain long-term motivation',
                description: 'Isolated gym routines lose their appeal over 12 months. Community and variety keep exercise sustainable.',
                links: [{ title: 'CDC Physical Activity Guidelines', url: 'https://www.cdc.gov/physicalactivity/basics/index.html' }, { title: 'Harvard: Cardiovascular Health', url: 'https://www.health.harvard.edu/heart-health' }, { title: 'Heart Rate Monitoring', url: 'https://www.mayoclinic.org/healthy-lifestyle/fitness/expert-answers/heart-rate/faq-20057979' }],
                tasks: [
                  { title: 'Try one new sport or recreation activity every 3 months (pickleball, rock climbing, rowing, martial arts)' },
                  { title: 'Join a running club, fitness class, or online challenge to add accountability and social connection' },
                  { title: 'Sign up for a physical event at Month 9 (5K, charity walk, bike ride) to create a meaningful fitness goal' },
                  { title: 'Build a "forever fitness" identity — exercise is part of who you are, not something you do temporarily' },
                  { title: 'Document your fitness transformation story to share with others and reinforce your identity' },
                ],
              },
            ],
          },
        ],
      },
      {
        title: 'Reprogram your mindset and identity for permanent change',
        description: 'Losing 50 lbs and keeping it off is 20% physical and 80% psychological. This strategy is what separates the people who succeed long-term.',
        objectives: [
          {
            title: 'Shift your identity from "someone trying to lose weight" to "a healthy person"',
            description: 'Identity drives behavior. When you believe you are a healthy person, you make healthy choices automatically.',
            measures: 'Daily self-affirmation practice established; at least 5 new "healthy person" behaviors adopted and sustained 60+ days',
            tactics: [
              {
                title: 'Build identity-based habits using small daily actions',
                description: 'Each healthy choice is a vote for the person you are becoming.',
                links: [{ title: 'Atomic Habits', url: 'https://jamesclear.com/atomic-habits' }, { title: 'Habitica Habit Tracker', url: 'https://www.habitica.com/' }, { title: 'BJ Fogg Behavior Model', url: 'https://www.behaviormodel.org/' }],
                tasks: [
                  { title: 'Write your identity statement: "I am a person who takes care of my body and prioritizes health"' },
                  { title: 'Read your identity statement every morning when you wake up' },
                  { title: 'List 10 small behaviors a healthy person does — pick 3 to start practicing immediately' },
                  { title: 'Each night, note one action you took that a healthy person would take' },
                  { title: 'Stop using diet language ("I am being good/bad") — replace with identity language ("This is how I eat now")' },
                ],
              },
              {
                title: 'Surround yourself with an environment and community that reinforces your new identity',
                description: 'You become the average of your environment. Redesign your surroundings to support the person you are becoming.',
                links: [{ title: 'Atomic Habits', url: 'https://jamesclear.com/atomic-habits' }, { title: 'Habitica Habit Tracker', url: 'https://www.habitica.com/' }, { title: 'BJ Fogg Behavior Model', url: 'https://www.behaviormodel.org/' }],
                tasks: [
                  { title: 'Identify 2–3 people in your life who support your health goals and spend more time with them' },
                  { title: 'Join an online or local weight-loss community where healthy behavior is the norm' },
                  { title: 'Redesign your home environment: stock only foods you would be proud to eat, remove the rest' },
                  { title: 'Tell people in your life about your transformation goal — social commitment dramatically increases follow-through' },
                  { title: 'Find one healthy-living role model whose habits you admire and study what they do daily' },
                ],
              },
            ],
          },
          {
            title: 'Develop resilience strategies for setbacks, plateaus, and hard weeks',
            description: 'At 50 lbs, you will plateau multiple times and have bad weeks. The ability to recover — not perfection — determines the outcome.',
            measures: 'Plateau-breaking plan documented; successful recovery from at least 2 setbacks without abandoning the goal',
            tactics: [
              {
                title: 'Build your plateau-breaking and bad-week recovery toolkit',
                description: 'Plan for failure so that failure does not end the journey.',
                links: [{ title: 'Sleep Hygiene', url: 'https://www.cdc.gov/sleep/about_sleep/sleep-hygiene.html' }, { title: 'Harvard Sleep Medicine', url: 'https://sleep.hms.harvard.edu/' }, { title: 'Better Sleep Tips', url: 'https://www.mayoclinic.org/healthy-lifestyle/adult-health/in-depth/sleep/art-20048379' }],
                tasks: [
                  { title: 'Write down exactly what you will do when you hit a plateau (reduce calories 100, add cardio session, or take a 2-week diet break)' },
                  { title: 'Write a "bad week recovery protocol" — 3 specific actions to take after going off plan' },
                  { title: 'Never let two bad days in a row become two bad weeks — restart the very next meal' },
                  { title: 'Schedule a deliberate 2-week "diet break" at Months 3 and 6 — eat at maintenance, keep exercising' },
                  { title: 'Join an online community (Reddit r/loseit, MyFitnessPal groups) for support during hard weeks' },
                ],
              },
              {
                title: 'Build mental toughness practices that sustain motivation across 12+ months',
                description: 'Motivation fades. Discipline, systems, and mental toughness carry you to the finish line.',
                links: [{ title: 'Atomic Habits', url: 'https://jamesclear.com/atomic-habits' }, { title: 'Habitica Habit Tracker', url: 'https://www.habitica.com/' }, { title: 'BJ Fogg Behavior Model', url: 'https://www.behaviormodel.org/' }],
                tasks: [
                  { title: 'Write down your top 3 "why" reasons and review them every morning — purpose sustains discipline' },
                  { title: 'Start a daily gratitude and progress journal — note one win per day, no matter how small' },
                  { title: 'Visualize your goal body and life for 5 minutes each morning — see, feel, and believe it' },
                  { title: 'Practice mindfulness or meditation 10 minutes per day to reduce stress-triggered eating' },
                  { title: 'Create a milestone reward system (new outfit at -10 lbs, weekend trip at -25 lbs, major experience at -50 lbs)' },
                ],
              },
            ],
          },
        ],
      },
      {
        title: 'Track progress rigorously and adjust the plan every 4 weeks',
        description: 'A 12-month goal requires a living plan — you will need to adjust the approach several times as your body adapts.',
        objectives: [
          {
            title: 'Maintain consistent weekly tracking across weight, nutrition, and fitness',
            description: 'The data tells you what to change. Without it, you are guessing.',
            measures: 'Weekly weigh-in logged 90%+ of weeks; monthly plan review completed every 4 weeks; 50 lbs lost within 14 months',
            tactics: [
              {
                title: 'Establish non-negotiable weekly and monthly review rituals',
                description: 'Build the review into your calendar like a meeting — it is not optional.',
                links: [{ title: 'Recommended Resource', url: 'https://www.example.com/' }],
                tasks: [
                  { title: 'Weigh in every Monday morning — same time, same conditions — and log it immediately' },
                  { title: 'Set a monthly calendar reminder for a 30-minute progress review' },
                  { title: 'At each monthly review: compare average weekly calories, workouts, steps, and weight trend' },
                  { title: 'Take progress photos every 30 days — front, side, back — body recomposition shows in photos before the scale' },
                  { title: 'Get bloodwork done at 3 months and 9 months to track health improvements beyond the scale' },
                  { title: 'Celebrate every 10-lb milestone with a meaningful non-food reward (new clothes, experience, equipment)' },
                ],
              },
              {
                title: 'Adapt the plan at 4-week intervals based on data and results',
                description: 'A 12-month plan must evolve with you — what worked at Month 1 may need adjustment by Month 6.',
                links: [{ title: 'Recommended Resource', url: 'https://www.example.com/' }],
                tasks: [
                  { title: 'Every 4 weeks review: average weekly calorie intake, workouts completed, weight lost vs. target' },
                  { title: 'If losing less than 1 lb/week for 3 weeks, reduce calories by 100 or add one 30-min cardio session' },
                  { title: 'If losing more than 2 lbs/week consistently, increase calories by 100 to protect muscle mass' },
                  { title: 'Update your TDEE estimate every 25 lbs lost — your maintenance calories decrease as you lose weight' },
                  { title: 'Schedule a 60-minute quarterly planning session to set goals for the next 90 days' },
                ],
              },
            ],
          },
          {
            title: 'Build a sustainable maintenance plan for after hitting goal weight',
            description: 'Reaching goal weight is only half the battle. A thoughtful transition plan prevents the common rebound.',
            measures: 'Maintenance phase documented before reaching goal weight; weight maintained within 5 lbs for 6+ months post-goal',
            tactics: [
              {
                title: 'Transition from deficit to maintenance calories gradually',
                description: 'Going straight from a large deficit to full maintenance often triggers rebound. Ease out slowly.',
                links: [{ title: 'Recommended Resource', url: 'https://www.example.com/' }],
                tasks: [
                  { title: 'When within 10 lbs of goal, reduce calorie deficit gradually (add 100 cal/week) over 6–8 weeks' },
                  { title: 'Recalculate TDEE at goal weight and use it as your new daily target' },
                  { title: 'Continue weekly weigh-ins — set a 5-lb buffer as your "action threshold" to prevent drift' },
                  { title: 'Maintain food logging at least 3 days per week to stay aware of intake without obsessing' },
                  { title: 'Continue strength training and cardio — these are the primary factors in weight maintenance long-term' },
                ],
              },
              {
                title: 'Create a long-term identity and lifestyle vision beyond the number on the scale',
                description: 'The goal was never just a number — it was a life. Define what that life looks like.',
                links: [{ title: 'Recommended Resource', url: 'https://www.example.com/' }],
                tasks: [
                  { title: 'Write a "healthy life vision" — describe your ideal daily routine, energy level, activities, and relationships at goal weight' },
                  { title: 'Identify 3 new health or fitness goals to pursue after the weight loss goal is complete' },
                  { title: 'Consider sharing your story — blog post, social media, or community — to inspire others and cement your new identity' },
                  { title: 'Schedule an annual health review every year to assess weight, bloodwork, fitness, and energy' },
                  { title: 'Give yourself full credit for the transformation — celebrate the discipline, not just the result' },
                ],
              },
            ],
          },
        ],
      },
    ],
  },
  {
    id: 'hw_energy',
    categoryId: 'health_wellness',
    title: 'Increase My Daily Energy and Vitality',
    description: 'Build sustainable habits around sleep, movement, nutrition, and recovery so you feel energized and alive every day.',
    strategies: [
      {
        title: 'Optimize sleep quality and quantity',
        description: 'Sleep is the foundation of sustained energy. Without it, every other effort is undermined.',
        objectives: [
          {
            title: 'Establish a consistent sleep schedule and environment',
            description: 'Your body thrives on routine. A consistent sleep-wake cycle regulates your natural energy rhythms.',
            measures: 'Sleeping 7–9 hours per night with consistent bed/wake times 6+ days per week',
            tactics: [
              {
                title: 'Design your sleep environment and evening routine',
                description: 'Small changes to your environment signal your nervous system that it is time to wind down.',
                links: [{ title: 'Sleep Hygiene', url: 'https://www.cdc.gov/sleep/about_sleep/sleep-hygiene.html' }, { title: 'Harvard Sleep Medicine', url: 'https://sleep.hms.harvard.edu/' }, { title: 'Better Sleep Tips', url: 'https://www.mayoclinic.org/healthy-lifestyle/adult-health/in-depth/sleep/art-20048379' }],
                tasks: [
                  { title: 'Set a fixed bedtime and wake time — even on weekends — and stick to it for 30 days' },
                  { title: 'Remove all screens from your bedroom and stop using phones 60 minutes before bed' },
                  { title: 'Lower your bedroom temperature to 65–68°F (18–20°C) for optimal sleep conditions' },
                  { title: 'Use blackout curtains or a sleep mask to eliminate light pollution' },
                  { title: 'Start a 20-minute wind-down ritual: light stretching, reading, or journaling — no news or social media' },
                ],
              },
              {
                title: 'Troubleshoot and resolve the hidden sleep disruptors affecting your energy',
                description: 'Even with good intentions, hidden habits can destroy sleep quality without you realizing it.',
                links: [{ title: 'Sleep Hygiene', url: 'https://www.cdc.gov/sleep/about_sleep/sleep-hygiene.html' }, { title: 'Harvard Sleep Medicine', url: 'https://sleep.hms.harvard.edu/' }, { title: 'Better Sleep Tips', url: 'https://www.mayoclinic.org/healthy-lifestyle/adult-health/in-depth/sleep/art-20048379' }],
                tasks: [
                  { title: 'Track your sleep for 2 weeks using a free app (Sleep Cycle, Pillow, or your phone\'s health app)' },
                  { title: 'Eliminate alcohol on weeknights — it fragments sleep in the second half of the night' },
                  { title: 'Cut off caffeine at noon to prevent it interfering with sleep onset and quality' },
                  { title: 'Avoid large meals within 2 hours of bedtime — digestion raises core body temperature and disrupts sleep' },
                  { title: 'If you wake frequently or snore, get screened for sleep apnea — it is more common and treatable than most people realize' },
                ],
              },
            ],
          },
          {
            title: 'Optimize morning routines to generate sustained energy from the first hour',
            description: 'How you start your morning sets the biochemical and psychological tone for the entire day.',
            measures: 'Consistent morning routine in place for 30+ days; self-reported morning energy rated 7+/10',
            tactics: [
              {
                title: 'Design an energizing morning routine anchored in light, movement, and hydration',
                description: 'The first 30–60 minutes of your day powerfully regulate cortisol, melatonin, and energy.',
                links: [{ title: 'Sleep Hygiene', url: 'https://www.cdc.gov/sleep/about_sleep/sleep-hygiene.html' }, { title: 'Harvard Sleep Medicine', url: 'https://sleep.hms.harvard.edu/' }, { title: 'Better Sleep Tips', url: 'https://www.mayoclinic.org/healthy-lifestyle/adult-health/in-depth/sleep/art-20048379' }],
                tasks: [
                  { title: 'Get outside or open bright windows within 10 minutes of waking to set your circadian rhythm' },
                  { title: 'Drink 16–20 oz of water immediately upon waking — overnight dehydration is a major cause of morning fatigue' },
                  { title: 'Do 5–10 minutes of light movement or stretching within the first 20 minutes of your day' },
                  { title: 'Delay your first coffee by 90 minutes after waking — this aligns caffeine with your natural cortisol dip' },
                  { title: 'Write 3 intentions for the day — purpose in the morning drives energy throughout the day' },
                ],
              },
              {
                title: 'Eliminate the morning habits that silently drain your energy before 9am',
                description: 'Common morning habits — phone-scrolling, skipping breakfast, rushing — spike cortisol and crash energy early.',
                links: [{ title: 'Sleep Hygiene', url: 'https://www.cdc.gov/sleep/about_sleep/sleep-hygiene.html' }, { title: 'Harvard Sleep Medicine', url: 'https://sleep.hms.harvard.edu/' }, { title: 'Better Sleep Tips', url: 'https://www.mayoclinic.org/healthy-lifestyle/adult-health/in-depth/sleep/art-20048379' }],
                tasks: [
                  { title: 'Do not check your phone or email for the first 30 minutes of the day — start in your own mind, not others\' agendas' },
                  { title: 'Eat a protein-rich breakfast (20+ grams) within 90 minutes of waking to stabilize blood sugar' },
                  { title: 'Stop hitting snooze — it fragments sleep and produces sleep inertia that drags on for hours' },
                  { title: 'Lay out your clothes, bag, and breakfast the night before to eliminate decision fatigue in the morning' },
                  { title: 'Rate your morning energy (1–10) for 2 weeks — use the pattern to identify which habits help vs. hurt' },
                ],
              },
            ],
          },
        ],
      },
      {
        title: 'Build daily movement and exercise habits',
        description: 'Regular physical activity is one of the most powerful energy boosters available.',
        objectives: [
          {
            title: 'Move your body intentionally every day',
            description: 'Even light movement dramatically increases mental clarity and physical energy throughout the day.',
            measures: 'At least 30 minutes of intentional movement 5+ days per week; energy levels rated 7+/10 consistently',
            tactics: [
              {
                title: 'Create a simple daily movement routine',
                description: 'Start small and build. Consistency matters more than intensity when building energy.',
                links: [{ title: 'Atomic Habits', url: 'https://jamesclear.com/atomic-habits' }, { title: 'Habitica Habit Tracker', url: 'https://www.habitica.com/' }, { title: 'BJ Fogg Behavior Model', url: 'https://www.behaviormodel.org/' }],
                tasks: [
                  { title: 'Take a 10-minute walk every morning — this alone will boost your mood and energy for hours' },
