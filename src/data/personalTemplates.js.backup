                links: [{ title: 'Meal Prep Ideas', url: 'https://www.eatthismuch.com/' }, { title: 'Harvard Nutrition Source', url: 'https://www.hsph.harvard.edu/nutritionsource/' }, { title: 'USDA MyPlate', url: 'https://www.myplate.gov/' }],
                tasks: [
                  { title: 'Get a blood panel checking Vitamin D, B12, iron, and magnesium — deficiencies are extremely common causes of fatigue' },
                  { title: 'Take a high-quality magnesium glycinate supplement (300–400 mg) before bed — magnesium supports hundreds of energy reactions' },
                  { title: 'Add omega-3-rich foods 3x per week (salmon, sardines, walnuts) — omega-3s reduce brain inflammation and support mental energy' },
                  { title: 'Add one dark leafy green daily (spinach, kale, Swiss chard) — packed with iron, folate, and B vitamins' },
                  { title: 'Discuss supplementation with your doctor if blood work shows deficiencies — targeted supplementation is more effective than guessing' },
                ],
              },
            ],
          },
          {
            title: 'Manage mental and emotional energy as carefully as physical energy',
            description: 'Mental fatigue is real and often the primary source of low energy — it depletes your body even without physical exertion.',
            measures: 'Stress levels rated 5 or lower (1–10) consistently; clear boundaries established around energy-draining commitments',
            tactics: [
              {
                title: 'Identify and reduce the primary mental energy drains in your life',
                description: 'Unresolved stress, toxic relationships, decision overload, and news consumption silently drain your energy reserves.',
                links: [{ title: 'Meal Prep Ideas', url: 'https://www.eatthismuch.com/' }, { title: 'Harvard Nutrition Source', url: 'https://www.hsph.harvard.edu/nutritionsource/' }, { title: 'USDA MyPlate', url: 'https://www.myplate.gov/' }],
                tasks: [
                  { title: 'List the top 5 things in your life that consistently drain your energy or create stress' },
                  { title: 'For each drain, identify whether it can be eliminated, delegated, reduced, or reframed' },
                  { title: 'Set firm screen time limits — cap social media and news consumption to 30 minutes per day' },
                  { title: 'Practice a 10-minute mindfulness or breathing exercise daily to reset your nervous system' },
                  { title: 'Reduce decision fatigue by automating low-stakes decisions (meal planning, outfit selection, routine scheduling)' },
                ],
              },
              {
                title: 'Build recovery and restoration practices into every day',
                description: 'Energy management is not just about input — it is about intentional recovery between outputs.',
                links: [{ title: 'Meal Prep Ideas', url: 'https://www.eatthismuch.com/' }, { title: 'Harvard Nutrition Source', url: 'https://www.hsph.harvard.edu/nutritionsource/' }, { title: 'USDA MyPlate', url: 'https://www.myplate.gov/' }],
                tasks: [
                  { title: 'Schedule one genuine rest period mid-day — a 10-minute walk, nap (under 20 min), or quiet break away from screens' },
                  { title: 'Block one evening per week as completely unstructured recovery time — no productivity, no obligations' },
                  { title: 'Practice deep breathing (4-7-8 or box breathing) for 5 minutes when you feel an energy crash coming' },
                  { title: 'Spend time in nature at least 2x per week — even 20 minutes outdoors measurably reduces cortisol and restores mental energy' },
                  { title: 'Audit your social calendar — identify which commitments drain you and which restore you, and rebalance toward the restorative' },
                ],
              },
            ],
          },
        ],
      },
    ],
  },
];

