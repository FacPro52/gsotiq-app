                tasks: [
                  { title: 'Choose your peak focus hours (morning, afternoon, evening)' },
                  { title: 'Design a 90-minute focus block (work + short break cycle)' },
                  { title: 'Identify 2-3 locations where you can focus without interruptions' },
                  { title: 'Set up your workspace: remove distractions, notification silenced, water/coffee ready' },
                  { title: 'Test your focus block once for real — measure output' },
                ],
              },
              {
                title: 'Protect focus blocks and build accountability',
