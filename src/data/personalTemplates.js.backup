  {
    id: 'hl_garden',
    categoryId: 'home_lifestyle',
    title: 'Create and Maintain a Home Garden',
    description: 'Design, build, and sustain a productive home vegetable or herb garden that provides fresh food, builds a rewarding routine, and connects you with nature.',
    category: 'home_lifestyle',
    strategies: [
      {
        title: 'Design and build your garden space',
        description: 'Choose the right location, prepare the soil, and build the infrastructure your garden needs before planting a single seed.',
        objectives: [
          {
            title: 'Select and prepare a suitable growing area by early spring',
            description: 'A well-sited, well-prepared bed is the single biggest factor in first-year success.',
            measures: 'Growing area selected, soil test completed, and beds built or cleared at least 2 weeks before last frost date',
            tactics: [
              {
                title: 'Assess your space and choose a garden format',
                description: 'Evaluate sunlight, drainage, and available space to decide between raised beds, in-ground rows, or containers.',
                links: [{ title: 'Recommended Resource', url: 'https://www.example.com/' }],
                tasks: [
                  { title: 'Walk your yard at different times of day and map areas that get 6+ hours of direct sun' },
                  { title: 'Research raised bed vs. in-ground vs. container pros and cons for your climate' },
                  { title: 'Decide on garden size — start small (4×8 ft raised bed is ideal for beginners)' },
                  { title: 'Sketch a rough layout showing bed placement, pathways, and water access' },
                ],
              },
              {
                title: 'Prepare and amend the soil',
                description: 'Healthy soil is the foundation — vegetables need loose, nutrient-rich, well-draining soil.',
                links: [{ title: 'Meal Prep Ideas', url: 'https://www.eatthismuch.com/' }, { title: 'Harvard Nutrition Source', url: 'https://www.hsph.harvard.edu/nutritionsource/' }, { title: 'USDA MyPlate', url: 'https://www.myplate.gov/' }],
                tasks: [
                  { title: 'Purchase a basic soil test kit or send a sample to your local extension office' },
                  { title: 'Source quality garden soil or compost (calculate cubic feet needed for bed depth of 12 inches)' },
                  { title: 'Build or buy raised bed frames, or till and edge in-ground area' },
                  { title: 'Fill beds and mix in compost, then let settle for 1–2 weeks before planting' },
                  { title: 'Set up a drip line, soaker hose, or plan a watering schedule' },
                ],
              },
            ],
          },
        ],
      },
      {
        title: 'Plan and execute your first planting season',
        description: 'Choose what to grow, when to plant, and how to start seeds — setting yourself up for a successful first harvest.',
        objectives: [
          {
            title: 'Successfully grow at least 5 varieties of vegetables or herbs this season',
            description: 'Variety gives you learning opportunities and a diverse harvest while keeping the workload manageable.',
            measures: 'At least 5 different crops harvested; success log noting which varieties thrived and which did not',
            tactics: [
              {
                title: 'Create a seasonal planting calendar',
                description: 'Timing is everything — knowing when to start seeds and when to transplant prevents the most common beginner mistakes.',
                links: [{ title: 'Recommended Resource', url: 'https://www.example.com/' }],
                tasks: [
                  { title: 'Look up your USDA hardiness zone and average last frost date' },
                  { title: 'Choose 5–8 beginner-friendly crops (e.g. tomatoes, zucchini, lettuce, basil, green beans, cucumbers)' },
                  { title: 'Build a planting calendar showing seed-start dates, transplant dates, and expected harvest windows' },
                  { title: 'Order or buy seeds and any starter supplies (seed trays, grow lights or sunny windowsill)' },
                ],
              },
              {
                title: 'Start seeds indoors and transplant on schedule',
                description: 'Getting a head start indoors gives warm-season crops like tomatoes and peppers the long growing season they need.',
                links: [{ title: 'Skillshare', url: 'https://www.skillshare.com/' }, { title: 'MasterClass', url: 'https://www.masterclass.com/' }, { title: 'Behance Portfolio', url: 'https://www.behance.net/' }],
                tasks: [
                  { title: 'Set up a seed-starting station with trays, seed-starting mix, and light source' },
                  { title: 'Sow tomatoes, peppers, and herbs indoors 6–8 weeks before last frost' },
                  { title: 'Direct-sow fast growers (lettuce, radishes, beans) straight into the garden bed' },
                  { title: 'Harden off seedlings outdoors for 7–10 days before transplanting' },
                  { title: 'Transplant seedlings to garden after last frost; label each row or plant' },
                ],
              },
            ],
          },
        ],
      },
      {
        title: 'Build a consistent garden maintenance routine',
        description: 'A garden thrives on regular attention — short, frequent sessions are far more effective than occasional heroic efforts.',
        objectives: [
          {
            title: 'Keep the garden healthy and productive through the full growing season',
            description: 'Consistent watering, feeding, and pest management prevents most problems before they become serious.',
            measures: 'Weekly maintenance log showing watering, weeding, fertilizing, and pest checks completed consistently',
            tactics: [
              {
                title: 'Establish a weekly garden care checklist',
                description: 'Break maintenance into short, repeatable tasks so nothing gets overlooked.',
                links: [{ title: 'Recommended Resource', url: 'https://www.example.com/' }],
                tasks: [
                  { title: 'Set a recurring calendar reminder for 2–3 short garden sessions per week (20–30 min each)' },
                  { title: 'Create a simple checklist: water, weed, check for pests, remove dead leaves' },
                  { title: 'Apply a balanced vegetable fertilizer or compost tea every 2–3 weeks' },
                  { title: 'Stake or cage tomatoes, cucumbers, and other climbers as they grow' },
                  { title: 'Install mulch (straw or wood chips) around plants to suppress weeds and retain moisture' },
                ],
              },
              {
                title: 'Monitor and manage pests and disease',
                description: 'Early detection and organic interventions prevent small pest problems from ruining an entire crop.',
                links: [{ title: 'Recommended Resource', url: 'https://www.example.com/' }],
                tasks: [
                  { title: 'Walk the garden each visit specifically looking at undersides of leaves for insects or eggs' },
                  { title: 'Identify the 5 most common pests in your area and learn their signs' },
                  { title: 'Stock basic organic controls: neem oil, insecticidal soap, row covers' },
                  { title: 'Research companion planting (e.g. basil near tomatoes, marigolds as a border) to deter pests naturally' },
                ],
              },
            ],
          },
        ],
      },
      {
        title: 'Harvest, evaluate, and plan for next season',
        description: 'Enjoying your harvest is the reward — and recording what worked sets you up for an even better garden next year.',
        objectives: [
          {
            title: 'Harvest produce regularly and conduct an end-of-season review',
            description: 'Tracking your harvest and lessons learned turns one good season into continuous improvement.',
            measures: 'Harvest log completed for each crop; end-of-season notes on variety performance, yield, and changes for next year',
            tactics: [
              {
                title: 'Track your harvest and compare to grocery costs',
                description: 'Logging what you grow gives you motivation and a baseline to improve on.',
                links: [{ title: 'Recommended Resource', url: 'https://www.example.com/' }],
                tasks: [
                  { title: 'Keep a simple harvest log (date, crop, approximate weight or count)' },
                  { title: 'Compare your harvest value to grocery store prices for the same produce' },
                  { title: 'Note any varieties that significantly over- or under-performed' },
                ],
              },
              {
                title: 'Prepare the garden for the off-season and plan next year',
                description: 'End-of-season care protects your soil investment and makes spring setup much easier.',
                links: [{ title: 'Meal Prep Ideas', url: 'https://www.eatthismuch.com/' }, { title: 'Harvard Nutrition Source', url: 'https://www.hsph.harvard.edu/nutritionsource/' }, { title: 'USDA MyPlate', url: 'https://www.myplate.gov/' }],
                tasks: [
                  { title: 'Pull spent plants and add healthy material to the compost bin' },
                  { title: 'Plant a winter cover crop (clover, rye) or mulch beds heavily to protect soil' },
                  { title: 'Write a brief "what I would do differently" note while the season is fresh in memory' },
                  { title: 'Browse seed catalogs and make a wish list for new varieties to try next year' },
                  { title: 'Order seeds for next season early (January–February) before popular varieties sell out' },
                ],
              },
            ],
          },
        ],
      },
    ],
  },
  {
    id: 'hl_balanced',
    categoryId: 'home_lifestyle',
    title: 'Build a Lifestyle That Feels Balanced and Fulfilling',
    description: 'Design a life where work, rest, relationships, health, and personal interests are in healthy proportion — leaving you energized and satisfied.',
    strategies: [
      {
        title: 'Audit your current lifestyle and identify the gaps',
        description: 'You cannot design a better life without first understanding where your current one falls short.',
        objectives: [
          {
