export const ALL_TEMPLATES = [
  ...healthTemplates,
  ...careerTemplates,
  ...financialTemplates,
  ...personalGrowthTemplates,
  ...educationTemplates,
  ...relationshipTemplates,
  ...homeLifestyleTemplates,
  ...creativityTemplates,
  ...travelTemplates,
  ...entrepreneurshipTemplates,
];

export const getTemplatesByCategory = (categoryId) =>
  ALL_TEMPLATES.filter((t) => t.categoryId === categoryId);

export const getTemplateById = (id) =>
  ALL_TEMPLATES.find((t) => t.id === id) || null;

export const getCategoryById = (id) =>
  TEMPLATE_CATEGORIES.find((c) => c.id === id) || null;

export const searchTemplates = (query) => {
  const q = query.toLowerCase();
  return ALL_TEMPLATES.filter(
    (t) =>
      t.title.toLowerCase().includes(q) ||
      t.description.toLowerCase().includes(q) ||
      t.strategies.some((s) => s.title.toLowerCase().includes(q))
  );
};
