        description: 'A consistent planning practice eliminates reactive work and ensures progress on priorities.',
        objectives: [
          {
            title: 'Complete a weekly planning ritual every Sunday for 12 consecutive weeks',
            description: 'Weekly planning is the highest-leverage productivity habit.',
