                  { title: 'Track your lifts weekly and add small increments — strength gains mean more metabolic capacity' },
                  { title: 'Prioritize sleep on training days — strength training improvements are made during recovery, not the workout itself' },
                  { title: 'Within 30 minutes of strength training, eat a protein-carb combination to accelerate recovery and reduce fatigue' },
                ],
              },
              {
                title: 'Use cardiovascular training to improve heart efficiency and mitochondrial density',
                description: 'Cardio increases mitochondrial density in your cells — literally more energy-producing units in every cell of your body.',
                links: [{ title: 'CDC Physical Activity Guidelines', url: 'https://www.cdc.gov/physicalactivity/basics/index.html' }, { title: 'Harvard: Cardiovascular Health', url: 'https://www.health.harvard.edu/heart-health' }, { title: 'Heart Rate Monitoring', url: 'https://www.mayoclinic.org/healthy-lifestyle/fitness/expert-answers/heart-rate/faq-20057979' }],
                tasks: [
                  { title: 'Do 2–3 low-intensity steady-state cardio sessions per week (Zone 2: conversational pace, 30–45 min)' },
                  { title: 'Zone 2 cardio is the single best training modality for mitochondrial health and sustainable energy' },
                  { title: 'Add one HIIT session per week (10–20 min, high intensity intervals) once base fitness is established' },
                  { title: 'Monitor resting heart rate weekly — a declining resting HR is the clearest sign of improved cardiovascular fitness' },
                  { title: 'Do not over-train — 4–5 workout days maximum; overtraining causes fatigue, not energy' },
