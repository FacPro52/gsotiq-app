                  { title: 'Take walking meetings or phone calls whenever possible — even slow walking boosts alertness' },
                  { title: 'When you feel an afternoon energy slump, do 20 jumping jacks or 10 pushups instead of reaching for coffee' },
                  { title: 'Take a 10-minute walk after lunch — this blunts the post-meal blood sugar spike that causes the 2pm crash' },
                  { title: 'Use standing for mentally draining tasks and sitting for deep creative work' },
