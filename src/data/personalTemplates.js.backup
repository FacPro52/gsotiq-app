                links: [{ title: 'Asana Project Management', url: 'https://asana.com/' }, { title: 'Getting Things Done', url: 'https://gettingthingsdone.com/' }, { title: 'OKR Framework', url: 'https://www.ycombinator.com/library/53-okrs' }],
                tasks: [
                  { title: 'Write a clear scope statement: exactly what is included and what is not' },
                  { title: 'Create an itemized cost estimate — get 3 contractor quotes for any work you won\'t DIY' },
                  { title: 'Add a 15% contingency buffer to all cost and time estimates' },
                  { title: 'Research permit requirements for your city before starting any structural work' },
                  { title: 'Create a project schedule with milestones and dependencies' },
                ],
              },
            ],
          },
          {
