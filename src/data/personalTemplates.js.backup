    description: 'Identify the self-limiting beliefs and internal narratives that are holding you back, and systematically replace them with empowering, accurate ones.',
    strategies: [
      {
        title: 'Surface and examine your limiting beliefs',
        description: 'You cannot change beliefs you are not aware of. Awareness is the foundation of all inner transformation.',
        objectives: [
          {
            title: 'Identify your top limiting beliefs across key life areas',
            description: 'Most people carry 5–10 core limiting beliefs that shape their choices and hold them back in multiple areas.',
            measures: 'Top limiting beliefs identified and written down; at least 3 root beliefs challenged and replaced',
            tactics: [
              {
                title: 'Conduct a deep limiting belief audit',
                description: 'Structured reflection exercises will surface beliefs that have been running invisibly in the background.',
                links: [{ title: 'Belief Systems', url: 'https://www.psychologytoday.com/us/basics/beliefs' }, { title: 'Cognitive Distortions', url: 'https://www.mindtools.com/pages/article/newTED_81.htm' }, { title: 'Limiting Beliefs', url: 'https://www.forbes.com/sites/ashleystahl/2020/06/26/how-to-overcome-limiting-beliefs/' }],
                tasks: [
                  { title: 'Complete the sentence: "I can\'t achieve [goal] because..." — write for 10 minutes without filtering' },
                  { title: 'List 5 areas where you consistently hold yourself back or self-sabotage — what do you believe about yourself there?' },
                  { title: 'For each limiting belief, ask: Is this actually true? Where did this come from? What evidence contradicts it?' },
                  { title: 'Work with a therapist or coach to explore beliefs with deeper roots if needed' },
                  { title: 'Write an empowering alternative belief for each limiting one — make it specific and believable' },
                ],
              },
              {
                title: 'Explore the origin and root causes of key limiting beliefs',
                description: 'Understanding where a belief came from weakens its grip on you.',
                links: [{ title: 'Childhood Origins of Beliefs', url: 'https://www.psychologytoday.com/us/basics/childhood' }, { title: 'Inner Child Work', url: 'https://www.verywellmind.com/what-is-inner-child-work-5205125' }],
                tasks: [
                  { title: 'For each top limiting belief, trace it back to its origin — who or what taught you this?' },
                  { title: 'Write about a specific memory or incident that reinforced this belief' },
                  { title: 'Consider: Was this ever true? Is it still true? Who decided this was true?' },
                  { title: 'Identify the emotional payoff or protection this belief has provided' },
                ],
              },
            ],
          },
          {
            title: 'Replace at least 3 limiting beliefs with empowering ones within 90 days',
            description: 'Belief change takes repetition, evidence, and emotional integration.',
            measures: 'At least 3 beliefs explicitly reframed; new beliefs adopted in language and behavior; evidence log maintained',
            tactics: [
              {
                title: 'Create empowering replacement beliefs backed by evidence',
                description: 'The new belief must feel real, not just positive-thinking fiction.',
                links: [{ title: 'Cognitive Reframing', url: 'https://www.mindtools.com/pages/article/newTED_97.htm' }, { title: 'Belief Change', url: 'https://www.verywellmind.com/changing-your-thoughts-4135029' }],
                tasks: [
                  { title: 'For each limiting belief, write: "A more empowering belief would be..."' },
                  { title: 'Gather 5–10 pieces of evidence (examples, experiences, stories) that support the new belief' },
                  { title: 'Craft a replacement belief that feels challenging but credible' },
                  { title: 'Test the new belief daily for 30 days and collect evidence that it\'s true' },
                ],
              },
              {
                title: 'Install the new belief through repetition and behavioral evidence',
                description: 'Beliefs change through experience, not just thinking.',
                links: [{ title: 'Neuroplasticity', url: 'https://www.mindtools.com/pages/article/neuroplasticity.htm' }, { title: 'Habits and Beliefs', url: 'https://jamesclear.com/atomic-habits' }],
                tasks: [
                  { title: 'Write your replacement belief on a sticky note and place it where you\'ll see it daily' },
                  { title: 'Read it aloud every morning and evening for 60 days' },
                  { title: 'Take one action each week that demonstrates you believe the new belief' },
                  { title: 'Track evidence: "Times I acted on my new belief this week"' },
                ],
              },
            ],
          },
        ],
      },
      {
        title: 'Build resilience against future limiting beliefs',
        description: 'The goal is not just to fix current beliefs, but to develop immunity to limiting thoughts.',
        objectives: [
          {
            title: 'Develop a belief evaluation system and practice using it regularly',
            description: 'Not every thought that crosses your mind deserves to become a belief.',
            measures: 'Belief evaluation system created and used on at least 5 situations per week for 60 days',
            tactics: [
              {
                title: 'Create a personal "belief court" system',
                description: 'Evaluate thoughts before they harden into beliefs.',
                links: [{ title: 'Thought Records', url: 'https://www.psychologytoday.com/us/basics/cognitive-therapy' }, { title: 'Cognitive Distortion', url: 'https://www.mindtools.com/pages/article/newTED_81.htm' }],
                tasks: [
                  { title: 'Design a simple 4-question system: Is this true? What\'s the evidence? What else could be true? What will I believe instead?' },
