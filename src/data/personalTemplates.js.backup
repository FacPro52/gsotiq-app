                  { title: 'Process inbox to zero twice daily — not continuously throughout the day' },
                ],
              },
            ],
          },
        ],
      },
      {
        title: 'Protect your energy and attention by building boundaries and eliminating low-value work',
        description: 'Reclaiming time requires learning to say no and protecting your capacity from low-impact work.',
        objectives: [
